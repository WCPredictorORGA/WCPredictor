# ──────────────────────────────────────────────
#  WCPredictor — variables d'environnement
#  Copier ce fichier : cp .env.example .env
#  Les valeurs ci-dessous fonctionnent telles
#  quelles pour un usage local avec Docker.
# ──────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=wcp
POSTGRES_PASSWORD=wcp_password
POSTGRES_DB=wcp_db

# Connexion BDD — « db » est le nom du service Docker, pas localhost
DATABASE_URL=postgresql://wcp:wcp_password@db:5432/wcp_db

# JWT — changer en production
JWT_SECRET=local_dev_secret_change_in_production

# CORS / Frontend
CORS_ORIGIN=http://localhost:5173
VITE_API_URL=http://localhost:3000

# Planificateur de scraping
SCRAPER_HOUR=10
SCRAPER_TZ=Europe/Paris
